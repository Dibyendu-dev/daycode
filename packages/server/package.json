{
    "name": "@daycode/server",
    "type": "module",
    "private": true,
    "exports": {
        ".": "./src/index.ts"
    },
    "scripts": {
        "dev": "bun run --watch --env-file=../../.env src/index.ts",
        "build": "bun build src/index.ts  --outdir dist --target bun",
        "postinstall": "bun -e \"process.env.DATABASE_URL&&require('child_process').execSync('bun run --cwd ../database db:generate',{stdio:'inherit'})\""
    },
    "dependencies": {
        "@ai-sdk/anthropic": "^3.0.81",
        "@ai-sdk/google": "^3.0.70",
        "@ai-sdk/openai": "^3.0.67",
        "@ai-sdk/provider-utils": "^4.0.27",
        "@clerk/backend": "^3.5.0",
        "@daycode/database": "workspace:*",
        "@daycode/shared": "workspace:*",
        "@sentry/bun": "^10.55.0",
        "@sentry/hono": "^10.55.0",
        "@hono/zod-validator": "^0.8.0",
        "@polar-sh/sdk": "^0.48.1",
        "@types/bun": "^1.3.14",
        "ai": "^6.0.193",
        "dotenv": "^17.4.2",
        "hono": "^4.12.23",
        "zod": "^4.4.3"
    }
}